{
  "name": "@wenyan-md/mcp",
  "version": "2.0.1",
  "description": "MCP server for Wenyan, a Markdown formatting tool that allows AI assistants to apply elegant built-in themes and publish articles directly to 微信公众号.",
  "author": "Lei <caol64@gmail.com> (https://github.com/caol64)",
  "license": "Apache-2.0",
  "keywords": [
    "公众号",
    "markdown",
    "文颜",
    "wenyan",
    "wechat",
    "publishing",
    "renderer",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "wenyan-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/caol64/wenyan-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caol64/wenyan-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/caol64/wenyan-mcp/issues"
  },
  "scripts": {
    "build": "pnpm --filter @wenyan-md/core build && tsc",
    "inspector": "pnpm build && node ./run-inspector.js",
    "test:tools": "pnpm build && node ./tests/listTools.js",
    "test:wechat-validation": "pnpm build && node ./tests/wechatValidation.js",
    "test:list": "pnpm build && dotenv -e .env.test -- node ./tests/list.js",
    "test:publish": "pnpm build && dotenv -e .env.test -- node ./tests/publish.js",
    "test:register": "pnpm build && dotenv -e .env.test -- node ./tests/registerTheme.js",
    "test:remove": "pnpm build && dotenv -e .env.test -- node ./tests/removeTheme.js",
    "prepublishOnly": "pnpm build"
  },
  "packageManager": "pnpm@10.7.1",
  "pnpm": {
    "preferWorkspacePackages": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "@wenyan-md/core": "workspace:*",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^24.3.0",
    "dotenv-cli": "^10.0.0",
    "openai": "^6.16.0",
    "typescript": "^5.9.2"
  }
}
